{
  "name": "bags-sdk-mcp",
  "version": "1.0.0",
  "description": "Batteries-included MCP server for the full Bags.fm API. 40 tools, 4 resources, 6 prompts, fee-config composer, agent lifecycle SDK, and autonomous agent mode.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bags-sdk-mcp": "./dist/bin/bags-sdk-mcp.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"const{cpSync,mkdirSync}=require('fs');mkdirSync('dist/src/signing',{recursive:true});cpSync('src/signing/page.html','dist/src/signing/page.html');cpSync('src/signing/scout-page.html','dist/src/signing/scout-page.html')\"",
    "dev": "tsc --watch",
    "start": "node dist/bin/bags-sdk-mcp.js",
    "start:http": "node dist/bin/bags-sdk-mcp.js --http",
    "start:agent": "node dist/bin/bags-sdk-mcp.js --agent",
    "inspect": "npx @modelcontextprotocol/inspector node dist/bin/bags-sdk-mcp.js",
    "test": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "bags",
    "bagsfm",
    "solana",
    "defi",
    "modelcontextprotocol",
    "ai-agent",
    "token-launch"
  ],
  "license": "MIT",
  "dependencies": {
    "@bagsfm/bags-sdk": "^1.2.7",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@solana/web3.js": "^1.95.0",
    "express": "^4.21.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "serve": "^14.2.6",
    "sharp": "^0.34.5",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
