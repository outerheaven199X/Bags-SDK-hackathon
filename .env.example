# Bags SDK MCP Server — Environment Configuration
# Requires Node.js >= 18

# Required
BAGS_API_KEY=                    # From dev.bags.fm

# Optional
BAGS_API_BASE=https://public-api-v2.bags.fm/api/v1  # Override for staging
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com   # Default RPC endpoint

# Agent mode - LLM keys (bring your own)
NOUS_API_KEY=                    # Hermes 4 for fast routine decisions (auto-claim, monitor)
ANTHROPIC_API_KEY=               # Any LLM API key for scout research + creative direction
AGENT_WALLET_PUBKEY=             # Base58 wallet for agent operations (read-only, no privkey)

# Scout mode - image generation (pick one provider)
IMAGE_GEN_PROVIDER=fal                 # "fal" or "replicate"
FAL_API_KEY=                           # fal.ai API key (uses Nano Banana 2 Pro for token logos)
REPLICATE_API_KEY=                     # Or Replicate API key instead

# Scout mode - configuration
SCOUT_INTERVAL=1800                    # Seconds between scan cycles (default: 30 min)
SCOUT_SOURCES=bags,news                # Comma-separated: bags, news
SCOUT_MAX_IDEAS=3                      # Max ideas per cycle
